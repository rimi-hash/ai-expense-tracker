# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual values

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Option 1: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/expense-tracker

# Option 2: MongoDB Atlas (Cloud)
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/expense-tracker

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a strong secret key for production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345
JWT_EXPIRE=7d

# ============================================
# AI/NLP SERVICE
# ============================================
# Option 1: OpenAI API (for advanced NLP categorization)
OPENAI_API_KEY=sk-your_openai_api_key_here

# Option 2: HuggingFace API (free alternative)
# HUGGINGFACE_API_KEY=hf_your_huggingface_token

# ============================================
# FRONTEND CONFIGURATION
# ============================================
# CORS: Which frontend domain can access this API
FRONTEND_URL=http://localhost:3000

# ============================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
